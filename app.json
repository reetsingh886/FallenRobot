{
  "name": "Fallen Robot",
  "description": "Telegram Group Management Bot.",
  "logo": "https://te.legra.ph/file/72e135da30a1a349f2844.jpg",
  "keywords": [
    "telegram",
    "modular",
    "group",
    "manager",
    "Fallen"
  ],
  "repository": "https://github.com/AnonymousX1025/FallenRobot",
  "stack": "heroku-22",

  "env": {
    "API_ID": {
      "description": "Get this value from my.telegram.org/apps.",
      "required": true
    },
    "API_HASH": {
      "description": "Get this value from my.telegram.org/apps.",
      "required": true
    },
    "ALLOW_EXCL": {
      "description": "Set True to allow ! as prefix",
      "value": "True"
    },
    "CASH_API_KEY": {
      "description": "Get from https://www.alphavantage.co/support/#api-key",
      "required": true
    },
    "DEL_CMDS": {
      "description": "Delete command messages if no permission",
      "value": "True"
    },
    "ENV": {
      "description": "Leave as True",
      "value": "True"
    },
    "EVENT_LOGS": {
      "description": "Channel ID like -100xxxx",
      "required": true
    },
    "MONGO_DB_URI": {
      "description": "MongoDB connection URI",
      "required": true
    },
    "OWNER_ID": {
      "description": "Your Telegram user ID",
      "value": "1356469075"
    },
    "START_IMG": {
      "description": "Telegraph image link",
      "required": true
    },
    "SUPPORT_CHAT": {
      "description": "Your support group username (without @)",
      "value": "DevilsHeavenMF"
    },
    "TIME_API_KEY": {
      "description": "Get from https://timezonedb.com/api",
      "required": true
    },
    "TOKEN": {
      "description": "Bot token from @BotFather",
      "required": true
    }
  }
}
